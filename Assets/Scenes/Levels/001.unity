  messages:
  - "\u0414\u043B\u044F \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u044F \u043D\u0430\u0436\u043C\u0438\u0442\u0435
    \u043A\u043D\u043E\u043F\u043A\u0443."
  - "\u0420\u0430\u0437\u043C\u0435\u0441\u0442\u0438\u0442\u0435 \u0431\u0430\u0448\u043D\u044E."
  - "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043F\u0443\u043B\u0435\u043C\u0435\u0442."
  - "\u0420\u0430\u0437\u0440\u0443\u0448\u0430\u0439\u0442\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u0439\u0442\u0435 \u043C\u043E\u043D\u0435\u0442\u044B."
  - "\u041F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u0442\u0435 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u0435."
  - "\u0423 \u0432\u0430\u0441 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043C\u043E\u043D\u0435\u0442 \u0434\u043B\u044F \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u044F."
  - 
  - "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u0435."
  - "\u0415\u0441\u043B\u0438 \u0431\u0430\u0448\u043D\u0438 \u043D\u0435 \u0441\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0442\u044F,
    \u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435\u0441\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438."
  - "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043F\u043E\u0440\u0442\u0430\u043B."
  - "\u041F\u0443\u043B\u0435\u043C\u0451\u0442\u044B \u043D\u0435 \u0441\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0442\u0441\u044F,
    \u043D\u0430\u043C \u043D\u0443\u0436\u043D\u0430 \u043F\u0443\u0448\u043A\u0430."
  - "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043F\u0443\u0448\u043A\u0443."
